{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Command Center",
  "version": "0.1.0",
  "identifier": "com.acc.desktop",
  "build": {
    "beforeDevCommand": "pnpm prepare:standalone && pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Command Center",
        "width": 1480,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/bin/acc-node",
      "resources/control-plane/index.cjs"
    ]
  }
}
